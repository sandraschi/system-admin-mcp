{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "System Admin MCP",
	"version": "0.1.0",
	"identifier": "ai.fleet.system-admin-mcp",
	"build": {
		"frontendDist": "../web_sota/dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "System Admin MCP",
				"width": 1280,
				"height": 860,
				"resizable": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis"],
		"icon": ["icons/icon.png", "icons/icon.ico"],
		"resources": [
			"resources/system-admin-mcp-backend.exe",
			"../scripts/install-mcp-clients.ps1"
		],
        "windows": {
			"webviewInstallMode": {
				"type": "skip"
			},
			"nsis": {
				"installMode": "currentUser",
				"installerHooks": "./windows/hooks.nsh"
			}
		}
	},
	"plugins": {}
}



