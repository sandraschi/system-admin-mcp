{
  "name": "system-admin-mcp",
  "version": "1.0.0",
  "description": "Windows system administration MCP server for file recovery, security management, volume maintenance, and diagnostics with Austrian precision",
  "author": "Sandra",
  "license": "MIT",
  "homepage": "https://github.com/sandraschi/system-admin-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/sandraschi/system-admin-mcp"
  },
  "main": "server/server.py",
  "mcp": {
    "version": "1.0",
    "capabilities": ["tools"],
    "prompts": {
      "system": "assets/prompts/system.md",
      "file_recovery": "assets/prompts/file_recovery.md",
      "security_management": "assets/prompts/security_management.md",
      "volume_maintenance": "assets/prompts/volume_maintenance.md",
      "system_diagnostics": "assets/prompts/system_diagnostics.md",
      "troubleshooting": "assets/prompts/troubleshooting.md"
    }
  },
  "runtime": {
    "python": ">=3.8"
    },
  "dependencies": {
    "fastmcp": ">=2.10.0",
    "pydantic": ">=2.0.0"
  },
  "features": [
    "File recovery from NTFS volumes",
    "Security and permission management",
    "Volume maintenance and disk operations",
    "System diagnostics and information collection",
    "Elevated privilege operations",
    "Windows-native integration",
    "Safe operation validation",
    "Austrian engineering quality"
  ],
  "requirements": {
    "os": ["Windows 10/11", "Windows Server 2016+"],
    "privileges": ["Administrator rights required for most operations"],
    "software": ["PowerShell 5.1+", "NTFS file system"]
  },
  "security": {
    "elevation": "Required for file recovery and security operations",
    "validation": "All operations validated before execution",
    "audit": "All privileged operations logged",
    "permissions": "Strict permission checks enforced"
          },
  "keywords": [
    "windows",
    "system-administration",
    "file-recovery",
    "security",
    "ntfs",
    "permissions",
    "diagnostics",
    "austria"
  ]
}
